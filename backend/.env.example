# Copy to .env and fill in secrets. FastAPI defaults to APP_PORT=8000; Kroki uses 8001.

APP_NAME=ai-sdlc-backend
APP_ENV=development
STORAGE_ROOT=storage
API_PREFIX=/api

KROKI_URL=http://localhost:8001

# Observability — Document Intelligence estimate ($/page)
DOCUMENT_INTELLIGENCE_USD_PER_PAGE=0.01

# Azure (required when wiring adapters)
AZURE_OPENAI_ENDPOINT=
AZURE_SEARCH_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
