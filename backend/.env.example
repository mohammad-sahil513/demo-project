# Copy to .env and fill in secrets. FastAPI defaults to APP_PORT=8000; Kroki uses 8001.
#
# Variable names and defaults mirror ``core.config.Settings`` (pydantic-settings).
# Production: set ``APP_ENV``/``APP_DEBUG``/``CORS_ORIGINS``/``KROKI_URL`` per
# ``docs/RELEASE_OPERATIONS.md``. Azure deployment strings must match the
# names shown in Azure OpenAI Studio for your resource (defaults below are
# code defaults only).

APP_NAME=ai-sdlc-backend
APP_ENV=development
# Production: set false to avoid verbose errors and stack traces in responses.
APP_DEBUG=true
LOG_LEVEL=INFO
# Console verbosity (keeps terminal quiet while workflow file logs remain rich).
LOG_CONSOLE_LEVEL=WARNING
# Console log shaping (only workflow phase/run progression lines).
LOG_CONSOLE_PHASE_ONLY=true
# Observability log retention in storage/logs.
LOG_CLEANUP_ENABLED=true
LOG_RETENTION_DAYS=14
# Set true for very detailed request + phase logs.
LOGS_VERBOSE=false

# Persistent directory for uploads, workflow JSON, outputs (use a mounted volume in Azure/K8s).
STORAGE_ROOT=storage
# Storage backend selector: local | blob
STORAGE_BACKEND=local
# Blob mode settings (required when STORAGE_BACKEND=blob)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_URL=
AZURE_STORAGE_CONTAINER=ai-sdlc-storage
API_PREFIX=/api

# Browser origins allowed to call the API (comma-separated). Use "*" only for dev.
# Production example: https://myapp.azurestaticapps.net,https://www.example.com
# With "*", cookie credentials are disabled (browser requirement).
CORS_ORIGINS=*

# Kroki sidecar base URL (no trailing slash). The app POSTs diagram sources here.
# Use a dedicated Kroki instance; do not point at arbitrary internal URLs (SSRF risk).
# See docs/RELEASE_OPERATIONS.md section "CORS, Kroki URL, and Azure deployment names".
KROKI_URL=http://localhost:8001

# Observability — Document Intelligence estimate ($/page)
DOCUMENT_INTELLIGENCE_USD_PER_PAGE=0.01

# Azure (required when wiring adapters)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-02-01
# Must match deployment names in Azure OpenAI (override if your resource uses different names).
AZURE_OPENAI_GPT5_DEPLOYMENT=gpt-5
AZURE_OPENAI_GPT5MINI_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=sdlc-chunks
RETRIEVAL_TOP_K=5
CHUNKER_TOKEN_MODE=tiktoken
HEADER_DETECTION_MODE=strict_row1
HEADER_SCAN_MAX_ROWS=5
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# --- Template fidelity (defaults match Settings; staging/production often override)
# Full semantics: docs/TEMPLATE_OPERATIONS.md
TEMPLATE_FIDELITY_STRICT_ENABLED=false
TEMPLATE_FIDELITY_PREVIEW_V2_ENABLED=false
TEMPLATE_PREVIEW_SAMPLE_FILL_ENABLED=true
TEMPLATE_SCHEMA_VALIDATION_BLOCKING=false
TEMPLATE_FIDELITY_MEDIA_INTEGRITY_BLOCKING=false
TEMPLATE_DOCX_PLACEHOLDER_NATIVE_ENABLED=false
TEMPLATE_SECTION_BINDING_STRICT=false
TEMPLATE_UPLOAD_NORMALIZE_ENABLED=false
TEMPLATE_DOCX_LEGACY_EXPORT_ALLOWED=true
TEMPLATE_DOCX_REQUIRE_NATIVE_FOR_CUSTOM=false
TEMPLATE_DOCX_STRUCTURE_FIXER_ENABLED=true
# inbuilt_only | all
TEMPLATE_DOCX_STRUCTURE_FIXER_SCOPE=inbuilt_only
TEMPLATE_CLASSIFIER_TIMEOUT_SECONDS=120
TEMPLATE_CLASSIFIER_MAX_RETRIES=2
