# API path prefix (same-origin) or full backend URL (cross-origin / production).
#
# Local dev (Vite proxies /api → backend): keep as /api
VITE_API_BASE=/api
#
# Production build when the SPA is on another host than the API, set at build time, e.g.:
# VITE_API_BASE=https://your-api.azurewebsites.net/api
# Then rebuild the frontend (`npm run build`). SSE and downloads use the same base.

# Where Vite forwards /api in dev (must match backend host:port). Not bundled into the client.
# BACKEND_ORIGIN=http://127.0.0.1:8000
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000
